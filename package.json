{
  "name": "coagent-app",
  "productName": "coagent",
  "version": "0.1.25",
  "description": "Desktop app for coagent — multi-participant chat for Claude Code agents",
  "author": {
    "name": "Vincent Jang",
    "email": "vincentjangdev@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/JangVincent/coagent-app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JangVincent/coagent-app.git"
  },
  "bugs": {
    "url": "https://github.com/JangVincent/coagent-app/issues"
  },
  "private": true,
  "type": "module",
  "main": "dist/main/main.cjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:agent": "esbuild src/agent-runtime/entry.ts --bundle --platform=node --format=cjs --outfile=dist/agent-runtime/entry.cjs --external:@anthropic-ai/claude-agent-sdk --external:ws --external:zod",
    "dev": "npm run build:agent && electron-vite dev",
    "build": "npm run build:agent && electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run build:agent && electron-vite dev",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "ci:make": "electron-forge make",
    "icons:mask": "node scripts/icon-mask.mjs",
    "icons": "npm run icons:mask && electron-icon-builder --input=./assets/icon.png --output=./assets --flatten"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "dompurify": "^3.2.5",
    "electron-squirrel-startup": "^1.0.1",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "update-electron-app": "^3.1.2",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron-forge/plugin-vite": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@reforged/maker-appimage": "^5.2.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^35.2.1",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^3.1.0",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "svelte": "^5.28.2",
    "svelte-check": "^4.1.6",
    "typescript": "^5.7.0",
    "vite": "^6.3.3"
  }
}
